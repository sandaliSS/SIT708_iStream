<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Video Player -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#000000" />

    <!-- Divider line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#E94560" />

    <!-- Controls -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/youtube_url_label"
                android:textColor="#B0B0C0"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/youtube_url_hint"
                android:inputType="textUri"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#808099"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/play_button"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E94560"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAddToPlaylist"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/add_to_playlist_button"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0F3460"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnMyPlaylist"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/my_playlist_button"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0F3460"
                android:layout_marginBottom="24dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2A2A4A"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/logout_button"
                android:textColor="#E94560"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:backgroundTint="#1A1A2E" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
